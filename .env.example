# hopium-api base URL (no trailing slash)
VITE_API_BASE_URL=https://api.hopium.bet

# Public URL of the TON Connect manifest JSON (icon, name, url)
VITE_TONCONNECT_MANIFEST_URL=https://hopium.bet/tonconnect-manifest.json

# Network selector
VITE_TON_NETWORK=testnet

# Deployed contract addresses (friendly form)
VITE_FACTORY_ADDRESS=
VITE_STAKING_ADDRESS=

# Telegram bot username (used for login widget + share/deeplinks)
VITE_BOT_USERNAME=hopiumbet_bot

# Optional error reporting
VITE_SENTRY_DSN=
